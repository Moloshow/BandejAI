# ============================================================
# BandejAI / Padelytics - Environment variables template
# ============================================================
# Copy this file to .env and adjust values as needed.
# NEVER commit the real .env file (already in .gitignore).
# ============================================================

# --- Runtime ---
# Random seed for reproducibility (all stochastic ops)
BANDEJAI_SEED=42

# Device selection: "cuda" (default) or "cpu"
BANDEJAI_DEVICE=cuda

# --- Paths ---
# Base directory for input videos and generated results
BANDEJAI_DATA_DIR=./data
BANDEJAI_OUTPUT_DIR=./results

# --- Models ---
# Directory where pretrained model weights are stored (not bundled)
BANDEJAI_MODELS_DIR=./models
# YOLOv8 weights filename (player detection)
BANDEJAI_YOLO_WEIGHTS=yolov8x.pt
# TrackNetV5 weights filename (ball tracking)
BANDEJAI_TRACKNET_WEIGHTS=TrackNetV5.pt
# ViTPose config & weights (pose estimation)
BANDEJAI_VITPOSE_CONFIG=vitpose_large_coco_256x192.py
BANDEJAI_VITPOSE_WEIGHTS=vitpose_large_coco_256x192.pth

# --- Audio ---
# Butterworth high-pass filter cutoff frequency (Hz)
BANDEJAI_AUDIO_HIGHPASS_HZ=10000

# --- LLM Coach ---
# Path to local quantized LLM (GGUF format)
BANDEJAI_LLM_MODEL=./models/hermes-2-pro-mistral-7b.Q4_K_M.gguf
# Maximum number of tokens to generate in coaching reports
BANDEJAI_LLM_MAX_TOKENS=2048