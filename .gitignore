# ─────────────────────────────────────────────────────────────
#  BandejAI / Padelytics — .gitignore
#  Python • Computer Vision • Machine Learning • OS • IDE
# ─────────────────────────────────────────────────────────────

# ── Private documentation (NOT open-sourced) ──
docs_private/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ──
venv/
.venv/
env/
ENV/

# ── Environment variables & secrets ──
.env
.env.*
*.pem
*.key
secrets/

# ── Model weights & checkpoints (too large for Git) ──
*.pt
*.pth
*.onnx
*.engine
*.tflite
*.h5
*.ckpt
*.safetensors
models/
weights/
checkpoints/

# ── Datasets & data files (too large / proprietary) ──
data/
datasets/
*.csv
*.parquet
*.npy
*.npz
*.hdf5
*.tfrecord

# ── Video files (raw match recordings) ──
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# ── Audio files (extracted during processing) ──
*.wav
*.mp3
*.flac
*.aac

# ── Outputs & results ──
results/
outputs/
output/
runs/
logs/
*.log

# ── Jupyter Notebook checkpoints ──
.ipynb_checkpoints/

# ── Type checkers / Linters cache ──
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS generated files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Docker ──
docker-compose.override.yml

# ── Misc / Temp ──
*.bak
*.tmp
*.temp
.cache/